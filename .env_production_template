# ── PRODUCTION DEPLOYMENT TEMPLATE ───────────────────────────────────────────
# Use these values in your Vercel (Frontend) and Render (Backend) Dashboards

# 1. Cloudflare R2 (Storage)
# Endpoint example: <account_id>.r2.cloudflarestorage.com
# PROD_MINIO_ENDPOINT=
# PROD_MINIO_ACCESS_KEY=
# PROD_MINIO_SECRET_KEY=
# PROD_MINIO_BUCKET=doc-chatbot
# PROD_MINIO_SECURE=true

# 2. Upstash Redis (Cache)
# PROD_REDIS_URL=redis://default:<token>@<endpoint>.upstash.io:6379

# 3. Neon DB (Database)
# You can use the same DATABASE_URL you have now!

# 4. Vercel Config
# On Vercel, set:
# NEXT_PUBLIC_API_URL=https://your-backend-on-render.com
